{
  "name": "siwes-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Institutional Industrial Training Management System (SIWES/IT)",
  "main": "src/server.js",
  "scripts": {
    "prestart": "npm run prisma:generate && npm run prisma:deploy",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "seed": "node src/scripts/seed.js",
    "lint": "eslint src/**/*.js",
    "docs": "node src/scripts/generateDocs.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f postgres",
    "backup:mongo": "node scripts/backup-mongodb.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "migrate:data": "node scripts/migrate-data.js"
  },
  "keywords": [
    "siwes",
    "industrial-training",
    "management-system",
    "education",
    "node",
    "express",
    "postgres"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.4",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "geolib": "^3.3.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "prisma": "^6.19.2",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^9.1.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
