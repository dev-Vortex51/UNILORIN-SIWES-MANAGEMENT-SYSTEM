{
  "version": "5.2",
  "steps": [
    {
      "tag": "CreateEnum",
      "enum": "AuditAction",
      "values": ["CREATE", "UPDATE", "DELETE", "LOGIN", "LOGOUT", "EXPORT", "APPROVE", "REJECT", "ASSIGN", "REVOKE"]
    },
    {
      "tag": "CreateTable",
      "table": "audit_logs",
      "columns": [
        { "name": "id", "type": "Text", "default": { "name": "uuid" }, "isGenerated": true },
